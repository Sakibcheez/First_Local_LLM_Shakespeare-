# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.pyx text eol=lf
*.pyc binary
*.pyo binary
*.pyd binary
*.so binary
*.egg binary

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Windows
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files
*.pyc binary
*.pyo binary
*.pkl binary
*.pickle binary
*.bin binary
*.pt binary
*.pth binary

# Large files (don't diff)
*.bin binary
*.pt binary
*.pth binary
*.ckpt binary
